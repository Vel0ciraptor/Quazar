# .env.example
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="http://localhost:3000"

# Admin Authentication
ADMIN_EMAIL="admin@quazar.com"
ADMIN_PASSWORD="quazar_admin_password"
JWT_SECRET="super_secret_jwt_key_change_me"

# Email Configuration (e.g., Resend, SendGrid, Gmail SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="your_smtp_password"
EMAIL_FROM="QUAZAR Tickets <tickets@quazar.com>"

# Payment Settings
WHATSAPP_NUMBER="+59170000000"
PAYMENT_QR_IMAGE_URL="/payment-qr-placeholder.png"
